{
  "manifest_version": 3,
  "name": "Discord XP Grinder Timer",
  "version": "1.0.0",
  "description": "Smart timer overlay for Discord to optimize XP grinding.",
  "action": {
    "default_title": "Discord XP Grinder"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.groq.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.discord.com/*"],
      "js": ["src/content.jsx"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["*://*.discord.com/*"]
    }
  ]
}
